{
  "name": "kizu",
  "version": "0.1.0",
  "description": "Kizu - Professional offline design tool",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:penpot\" \"npm run dev:electron\"",
    "dev:penpot": "cd ../penpot && ./manage.sh run-devenv",
    "dev:electron": "concurrently \"npm run scss:watch\" \"nodemon --watch src --exec 'electron .'\"",
    "dev:full": "concurrently \"npm run dev:penpot\" \"npm run scss:watch\" \"nodemon --watch src --exec 'electron .'\"",
    "build": "npm run build:penpot && npm run build:electron",
    "build:penpot": "cd ../penpot && npm run build:frontend",
    "build:electron": "electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "pack": "electron-builder --dir",
    "test": "node test-suite.js",
    "test:auth": "playwright test test/auth-integration.test.js",
    "test:auth:headed": "playwright test test/auth-integration.test.js --headed",
    "test:auth:debug": "playwright test test/auth-integration.test.js --headed --debug",
    "test:integration": "node integration-test.js",
    "test:functionality": "node kizu-functionality-test.js",
    "test:design-tools": "node kizu-design-tools-test.js",
    "test:basic-functionality": "node test-basic-penpot-functionality.js",
    "test:unit": "jest",
    "test:figma": "jest --testPathPattern=tests/unit/figma",
    "test:all": "jest",
    "lint": "eslint src/ --fix",
    "lint:check": "eslint src/",
    "lint:css": "stylelint \"src/**/*.css\" \"src/**/*.scss\" --fix",
    "lint:css:check": "stylelint \"src/**/*.css\" \"src/**/*.scss\"",
    "format": "prettier --write src/ *.js",
    "format:check": "prettier --check src/ *.js",
    "code-quality": "npm run lint:check && npm run lint:css:check && npm run format:check",
    "scss": "sass src/styles/desktop.scss src/styles/desktop.css",
    "scss:watch": "sass --watch src/styles/desktop.scss src/styles/desktop.css",
    "prepare": "husky"
  },
  "keywords": [
    "design",
    "desktop",
    "kizu",
    "figma-alternative",
    "offline"
  ],
  "author": "Kizu Team",
  "license": "MIT",
  "homepage": "https://github.com/ollehca/Kizu",
  "repository": {
    "type": "git",
    "url": "https://github.com/ollehca/Kizu"
  },
  "build": {
    "appId": "com.kizu.app",
    "productName": "Kizu 築",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../penpot/frontend/resources/public",
        "to": "penpot-frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.graphics-design",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons/512x512.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.56.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.5",
    "nodemon": "^3.1.9",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "sass": "^1.90.0",
    "stylelint": "^16.25.0",
    "stylelint-config-sass-guidelines": "^12.1.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.0"
  },
  "dependencies": {
    "@mongodb-js/zstd": "^2.0.1",
    "@penpot/library": "^1.0.11",
    "adm-zip": "^0.5.16",
    "base64-js": "^1.5.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "fig-kiwi": "^0.0.1",
    "kiwi-schema": "^0.5.0",
    "node-fetch": "^2.6.7",
    "pako": "^2.1.0",
    "transit-js": "^0.8.874"
  }
}
